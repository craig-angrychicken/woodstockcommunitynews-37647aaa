{
  // Cloudflare Workers config for the WCN API + pipeline (all-Cloudflare / D1 stack).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wcn-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // Serve the API (and admin image thumbnails) under the admin hostname so the SPA is same-origin
  // and one Cloudflare Access login covers both. The Pages project serves the rest of admin.*.
  "routes": [
    { "pattern": "admin.woodstockcommunity.news/api/*", "zone_name": "woodstockcommunity.news" },
    { "pattern": "admin.woodstockcommunity.news/images/*", "zone_name": "woodstockcommunity.news" }
  ],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wcn",
      "database_id": "7b161ae7-7f3c-42fd-a627-dd3fb1058f14"
    }
  ],

  "r2_buckets": [
    {
      "binding": "ARTIFACT_IMAGES",
      "bucket_name": "artifact-images"
    }
  ],

  "vars": {
    "PUBLIC_SITE_URL": "https://woodstockcommunity.news",
    // Cloudflare Access team domain + AUD for verifying admin JWTs.
    "ACCESS_TEAM_DOMAIN": "holy-bar-b3ad.cloudflareaccess.com",
    "ACCESS_AUD": "e69f5d02d7d2b9209dd90ea9cf77f3b466da84842110e42736bc8383fb3f3f06"
  },

  "queues": {
    "producers": [{ "binding": "JOURNALISM_QUEUE", "queue": "wcn-journalism" }],
    "consumers": [
      {
        "queue": "wcn-journalism",
        "max_batch_size": 1,
        "max_concurrency": 1,
        "max_retries": 3,
        "dead_letter_queue": "wcn-journalism-dlq"
      }
    ]
  },

  // Cron expressions map (in src/cron.ts) to: fetch+recover (15m), cluster (4x/hr),
  // journalism (4x/hr), editorial (3x/hr), council scrape (3x/day).
  "triggers": {
    "crons": ["*/15 * * * *", "5,20,35,50 * * * *", "10,25,40,55 * * * *", "14,34,54 * * * *", "0 8,14,20 * * *"]
  }

  // Secrets (wrangler secret put): OPENROUTER_API_KEY, LOVABLE_API_KEY, RESEND_API_KEY,
  //   ALERT_EMAIL, FACEBOOK_PAGE_ACCESS_TOKEN, FACEBOOK_PAGE_ID, FACEBOOK_PLACE_ID,
  //   QUEUE_PROCESSOR_SECRET, REVALIDATION_SECRET, R2_PUBLIC_URL.
}
