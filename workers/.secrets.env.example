# Worker secrets loader input. Copy to .secrets.env (gitignored), fill the values
# you have, then run:  bash scripts/set-secrets.sh
#
# Auto-handled by the script (leave blank):
#   OPENROUTER_API_KEY  → pulled from /Users/craigbaltes/coding/RISO4/viewer/.env.local if blank
#   QUEUE_PROCESSOR_SECRET, REVALIDATION_SECRET → generated (openssl) if blank
#   ALERT_EMAIL → defaults to craig@angrychicken.co
#
# These you must paste (not recoverable from Supabase — digests only):
RESEND_API_KEY=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PLACE_ID=
# Optional (leave blank to disable the Lovable LLM fallback):
LOVABLE_API_KEY=
# Optional overrides (leave blank for auto):
OPENROUTER_API_KEY=
QUEUE_PROCESSOR_SECRET=
REVALIDATION_SECRET=
ALERT_EMAIL=
